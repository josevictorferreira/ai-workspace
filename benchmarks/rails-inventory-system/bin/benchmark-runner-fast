#!/usr/bin/env bash
set -euo pipefail

readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly REPO_ROOT="$SCRIPT_DIR/.."
readonly RELATIVE_PATH="benchmarks/rails-inventory-system"

# Re-exec in nix shell if not already in one
if [[ -z "${IN_NIX_SHELL:-}" ]] && [[ -f "$REPO_ROOT/flake.nix" ]]; then
  echo "Re-executing in nix develop..."
  exec nix develop "$REPO_ROOT" --impure --command bash "$SCRIPT_DIR/benchmark-runner-fast" "$@"
fi

# Defaults
worktree_root="$REPO_ROOT/.sisyphus/worktrees-fast"
timeout_opencode_sec=3600
timeout_rspec_sec=300
keep_worktrees=false
opencode_config_path=""

# Parse CLI args
while [[ $# -gt 0 ]]; do
  case "$1" in
    --keep-worktrees)
      keep_worktrees=true
      shift
      ;;
    --worktree-root)
      if [[ -z "${2:-}" ]]; then echo "Error: --worktree-root requires an argument" >&2; exit 1; fi
      worktree_root="$2"
      shift 2
      ;;
    --timeout-opencode-sec)
      if [[ -z "${2:-}" ]]; then echo "Error: --timeout-opencode-sec requires an argument" >&2; exit 1; fi
      timeout_opencode_sec="$2"
      shift 2
      ;;
    --timeout-rspec-sec)
      if [[ -z "${2:-}" ]]; then echo "Error: --timeout-rspec-sec requires an argument" >&2; exit 1; fi
      timeout_rspec_sec="$2"
      shift 2
      ;;
    --opencode-config)
      if [[ -z "${2:-}" ]]; then echo "Error: --opencode-config requires an argument" >&2; exit 1; fi
      opencode_config_path="$2"
      shift 2
      ;;
    -h|--help)
      cat << 'EOF'
Usage: MODEL=<model> ./bin/benchmark-runner-fast [options]

Runs benchmark on v1/failing branch using specified model.

Options:
  --keep-worktrees
  --worktree-root PATH (default: .sisyphus/worktrees-fast)
  --timeout-opencode-sec SEC (default: 3600)
  --timeout-rspec-sec SEC (default: 300)
  --opencode-config FILE
  -h, --help

Env: MODEL required, opencode in PATH
EOF
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      exit 1
      ;;
  esac
done

# Required env check
if [[ -z "${MODEL:-}" ]]; then
  echo "Error: MODEL env var required" >&2
  exit 1
fi

if ! command -v opencode >/dev/null 2>&1; then
  echo "Error: opencode not in PATH" >&2
  exit 1
fi

# Compute derived values
MODEL_SLUG="$(echo "$MODEL" | tr '[:upper:]' '[:lower:]' | tr -c 'a-z0-9' '_' | tr -s '_' | sed 's/^_\|_$//g')"
FAIL_BRANCH="v1/failing"
FIX_BRANCH="v1/fix/${MODEL_SLUG}"

# Results file
RESULTS_FILE="$REPO_ROOT/.sisyphus/benchmark-results-fast.md"

# Array to track worktrees for cleanup
declare -a worktrees_to_remove=()

cleanup() {
  if [[ "$keep_worktrees" != true ]]; then
    echo "Cleaning up worktrees..."
    for wt in "${worktrees_to_remove[@]}"; do
      if [[ -d "$wt" ]]; then
        worktree_remove "$wt" 2>/dev/null || true
      fi
    done
    git worktree prune 2>/dev/null || true
  fi
}
trap cleanup EXIT INT TERM

model_slug() {
  echo "$1" | tr '[:upper:]' '[:lower:]' | tr -c 'a-z0-9' '_' | tr -s '_' | sed 's/^_\|_$//g'
}

worktree_add() {
  local fail_branch="$1"
  local fix_branch="$2"
  local wt_path="$3"

  git_create_fix_branch "$fail_branch" "$fix_branch"
  git worktree add "$wt_path" "$fix_branch" 2>/dev/null || {
    echo "Worktree already exists at $wt_path, removing..." >&2
    worktree_remove "$wt_path"
    git worktree add "$wt_path" "$fix_branch"
  }
  echo "Added worktree: $wt_path (fail: $fail_branch -> fix: $fix_branch)"
}

worktree_remove() {
  local wt_path="$1"
  git worktree remove "$wt_path" 2>/dev/null || true
  rm -rf "$wt_path"
}

git_create_fix_branch() {
  local fail_branch="$1"
  local fix_branch="$2"
  if git branch --list "$fix_branch" | grep -q "$fix_branch"; then
    echo "Fix branch $fix_branch already exists"
  else
    git branch "$fix_branch" "$fail_branch"
  fi
}

git_is_dirty() {
  local wt_path="$1"
  [[ -n $(cd "$wt_path" && git status --porcelain) ]]
}

git_auto_commit() {
  local wt_path="$1"
  local model_slug="$2"

  cd "$wt_path" || return 1

  if ! git_is_dirty "$wt_path"; then
    echo "Working tree clean, nothing to commit"
    return 0
  fi

  git add -A
  git commit -m "fix: rspec failures via ${model_slug}"
  git rev-parse HEAD
}

results_init() {
  mkdir -p "$(dirname "$RESULTS_FILE")"
  cat > "$RESULTS_FILE" << 'EOF'
# Fast Benchmark Results

| timestamp | model | pre_failures | post_failures | fixed | status | commit | log_dir |
|-----------|-------|--------------|---------------|-------|--------|--------|---------|
EOF
}

results_add_row() {
  local timestamp="$1"
  local model="$2"
  local pre="$3"
  local post="$4"
  local fixed="$5"
  local status="$6"
  local commit="$7"
  local log_dir="$8"

  echo "| $timestamp | $model | $pre | $post | $fixed | $status | $commit | $log_dir |" >> "$RESULTS_FILE"
}

db_test_env_number() {
  # Use empty TEST_ENV_NUMBER to use default test database
  echo ""
}

db_prepare() {
  local worktree_path="$1"
  local test_env_number="$2"
  local project_path="$worktree_path/$RELATIVE_PATH"
  local log_file="$project_path/db_prepare.log"
  local bundle_cache="$REPO_ROOT/.sisyphus/bundle-cache"
  mkdir -p "$(dirname "$log_file")"
  cd "$project_path" || return 1
  env BUNDLE_PATH="$bundle_cache" PATH="$bundle_cache/bin:$PATH" timeout ${timeout_rspec_sec}s bash -c "
    RAILS_ENV=test TEST_ENV_NUMBER='$test_env_number' ./bin/rails db:prepare 2>&1 | tee 'db_prepare.log'
  " || {
    echo "db_prepare failed for $test_env_number (check $log_file)" >&2
    return 1
  }
  echo "db_prepare succeeded for $test_env_number"
}

db_drop() {
  local worktree_path="$1"
  local test_env_number="$2"
  local project_path="$worktree_path/$RELATIVE_PATH"
  local bundle_cache="$REPO_ROOT/.sisyphus/bundle-cache"
  cd "$project_path" || return 0
  echo "Dropping DBs for $test_env_number: inventory_system_test${test_env_number}, inventory_system_test${test_env_number}_queue"
  env BUNDLE_PATH="$bundle_cache" PATH="$bundle_cache/bin:$PATH" RAILS_ENV=test TEST_ENV_NUMBER="$test_env_number" ./bin/rails db:drop 2>/dev/null || true
  echo "db_drop completed for $test_env_number"
}

rspec_run() {
  local worktree_path="$1"
  local test_env_number="$2"
  local phase="$3"
  local log_dir="$4"
  local project_path="$worktree_path/$RELATIVE_PATH"
  local log_path="$log_dir/rspec-${phase}.log"
  local bundle_cache="$REPO_ROOT/.sisyphus/bundle-cache"
  mkdir -p "$log_dir"

  local start_sec=$(date +%s)

  timeout "${timeout_rspec_sec}s" \
    env BUNDLE_PATH="$bundle_cache" TEST_ENV_NUMBER="$test_env_number" PATH="$bundle_cache/bin:$PATH" \
    bash -c "cd '$project_path' && bundle exec rspec" \
    > "$log_path" 2>&1

  local exit_code=$?
  local elapsed_sec=$(( $(date +%s) - start_sec ))
  # Parse failures count from rspec summary line like "31 examples, 14 failures"
  local failures=$(tail -n 30 "$log_path" 2>/dev/null | grep -E "[0-9]+ failure" | tail -1 | sed -E 's/.*([0-9]+) failure.*/\1/' | grep -E "^[0-9]+$" || echo 0)
  # Ensure failures is a single number
  failures=$(echo "$failures" | head -1)
  [[ -z "$failures" ]] && failures=0
  local status=$( [[ "$failures" -eq 0 ]] && echo "PASS" || echo "FAIL" )

  echo "{\"exit_code\":$exit_code,\"elapsed_sec\":$elapsed_sec,\"status\":\"$status\",\"failures\":$failures,\"log_path\":\"$log_path\"}"
}

generate_prompt_md() {
  local worktree_path="$1"
  local rspec_pre_log="$2"
  local project_path="$worktree_path/$RELATIVE_PATH"

  local prompt_md="$project_path/PROMPT.md"

  cat > "$prompt_md" << 'HEADER'
## Project Context

This is a **Ruby on Rails 8.1 API-only** application implementing an **Order and Inventory Management System**. The system manages products, warehouses, and inventory stock, handling the full lifecycle of an order from pending to confirmed or cancelled.

### Key Features
- **Multi-Warehouse Support**: Inventory is tracked per warehouse.
- **Stock Allocation Logic**: Orders are confirmed by deducting stock from warehouses in ascending ID order.
- **Atomic Transactions**: Inventory deductions and order status updates are performed within database transactions to ensure data integrity.
- **Inventory Restoration**: Cancelling a confirmed order accurately restores stock to the original warehouses using an allocation tracking system.
- **State Integrity**: Strict guards prevent modifying orders once they are confirmed or cancelled.
- **Deterministic Business Logic**: All line total and order total calculations are performed within the application domain.

### Tech Stack
- **Language**: Ruby 3.x
- **Framework**: Rails 8.1 (API-only mode)
- **Database**: PostgreSQL
- **Testing**: RSpec, FactoryBot, Shoulda Matchers

See full details in AGENTS.md.

HEADER

  echo "" >> "$prompt_md"
  echo "## Current Branch" >> "$prompt_md"
  echo "" >> "$prompt_md"
  echo "You are working on the \`v1/failing\` branch." >> "$prompt_md"
  echo "" >> "$prompt_md"
  echo "## Task" >> "$prompt_md"
  echo "" >> "$prompt_md"
  echo "Fix the failing tests so that \`bundle exec rspec\` passes." >> "$prompt_md"
  echo "" >> "$prompt_md"
  echo "- Do NOT change the intended business logic or introduce scope creep." >> "$prompt_md"
  echo "- Do NOT modify database.yml or change database configuration." >> "$prompt_md"
  echo "- Do NOT add new migrations or change the schema." >> "$prompt_md"
  echo "- Focus only on fixing the failing test cases." >> "$prompt_md"
  echo "- Make minimal changes to get tests passing." >> "$prompt_md"
  echo "" >> "$prompt_md"

  if [[ -f "$rspec_pre_log" ]]; then
    echo "## Failing Test Output" >> "$prompt_md"
    echo "" >> "$prompt_md"
    echo '```' >> "$prompt_md"
    tail -n 100 "$rspec_pre_log" >> "$prompt_md" 2>/dev/null || cat "$rspec_pre_log" >> "$prompt_md"
    echo '```' >> "$prompt_md"
    echo "" >> "$prompt_md"
  fi

  echo "## Instructions" >> "$prompt_md"
  echo "" >> "$prompt_md"
  echo "1. Read the failing test output above." >> "$prompt_md"
  echo "2. Identify the root cause of the failures." >> "$prompt_md"
  echo "3. Make the minimal code changes needed to fix the tests." >> "$prompt_md"
  echo "4. Run \`bundle exec rspec\` to verify your fixes." >> "$prompt_md"
  echo "5. Commit your changes when all tests pass." >> "$prompt_md"
  echo "" >> "$prompt_md"
  echo "Do not ask the user questions - work autonomously." >> "$prompt_md"

  echo "Created PROMPT.md at $prompt_md"
}

opencode_run() {
  local worktree_path="$1"
  local prompt_path="$2"
  local log_path="$3"

  local project_path="$worktree_path/$RELATIVE_PATH"
  local start_sec=$(date +%s)

  cd "$project_path" || {
    echo "{\"exit_code\":1,\"elapsed_sec\":0,\"log_path\":\"$log_path\"}"
    return 1
  }

  # Run opencode with benchmark config (auto-allows edits, blocks git/web)
  # Pass API key env vars explicitly
  # Use a here-document to pass the prompt content
  (cd "$project_path" && env OPENCODE_DISABLE_CLAUDE_CODE=1 \
    OPENCODE_CONFIG="$HOME/.config/opencode/opencode.json.benchmark" \
    OPENROUTER_API_KEY_CODE_AGENT="${OPENROUTER_API_KEY_CODE_AGENT:-}" \
    OPENAI_API_KEY="${OPENAI_API_KEY:-}" \
    ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY:-}" \
    GROQ_API_KEY="${GROQ_API_KEY:-}" \
    DEEPSEEK_API_KEY="${DEEPSEEK_API_KEY:-}" \
    XAI_API_KEY="${XAI_API_KEY:-}" \
    timeout "${timeout_opencode_sec}s" opencode run --model "$MODEL" --dir . --attach $(cat "$prompt_path")) > "$log_path" 2>&1

  local exit_code=$?
  local elapsed_sec=$(( $(date +%s) - start_sec ))

  echo "{\"exit_code\":$exit_code,\"elapsed_sec\":$elapsed_sec,\"log_path\":\"$log_path\"}"
}

main() {
  local timestamp=$(date +%Y%m%d-%H%M%S)
  local log_root="$REPO_ROOT/.sisyphus/bench-logs-fast/$timestamp"
  mkdir -p "$log_root"

  results_init

  local wt_path="$worktree_root/fast-$MODEL_SLUG"
  local log_dir="$log_root/$MODEL_SLUG"
  mkdir -p "$log_dir"

  worktrees_to_remove+=("$wt_path")

  worktree_add "$FAIL_BRANCH" "$FIX_BRANCH" "$wt_path"

  local test_env=""
  local project_path="$wt_path/$RELATIVE_PATH"
  local bundle_cache="$REPO_ROOT/.sisyphus/bundle-cache"

  echo "Installing bundle..."
  (cd "$project_path" && BUNDLE_PATH="$bundle_cache" bundle install 2>&1 | tee "$log_root/bundle-install.log") || {
    echo "Bundle install failed" >&2
    exit 1
  }

  db_prepare "$wt_path" "$test_env"

  echo "=== RSpec PRE ==="
  local pre_result=$(rspec_run "$wt_path" "$test_env" "pre" "$log_dir")
  local pre_failures=$(echo "$pre_result" | jq -r .failures)
  local pre_log=$(echo "$pre_result" | jq -r .log_path)

  generate_prompt_md "$wt_path" "$pre_log"

  echo "=== OpenCode ==="
  local opencode_log="$log_dir/opencode.log"
  local prompt_path="$wt_path/$RELATIVE_PATH/PROMPT.md"
  local opencode_result=$(opencode_run "$wt_path" "$prompt_path" "$opencode_log")

  echo "=== RSpec POST ==="
  local post_result=$(rspec_run "$wt_path" "$test_env" "post" "$log_dir")
  local post_failures=$(echo "$post_result" | jq -r .failures)
  local status=$( [[ "$post_failures" == "0" ]] && echo "PASS" || echo "FAIL" )
  local fixed=$(( pre_failures - post_failures ))

  local commit_sha=""
  if [[ "$status" == "PASS" ]]; then
    commit_sha=$(git_auto_commit "$wt_path" "$MODEL_SLUG")
  fi

  results_add_row "$timestamp" "$MODEL" "$pre_failures" "$post_failures" "$fixed" "$status" "$commit_sha" "$log_dir"

  db_drop "$wt_path" "$test_env"

  echo "Benchmark complete. Results: $RESULTS_FILE"
  echo "Logs: $log_dir"
}

main "$@"
