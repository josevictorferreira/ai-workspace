#!/usr/bin/env bash
set -euo pipefail

# Benchmark Runner Foundation (Tasks 1-3)
# - CLI parsing, env gating, nix re-exec
# - Model slugify + branch naming
# - Worktree lifecycle + cleanup trap
#
# Usage:
#   MODEL=grok-4 ./bin/benchmark-runner --branches 'v1/fail/*' --filter 'order_spec' \\
#     --worktree-root .sisyphus/worktrees --timeout-opencode-sec 300 --keep-worktrees
#
# Debug:
#   ./bin/benchmark-runner --print-names --branches 'v1/fail/*'
#
# Required: MODEL env var, opencode in PATH
# Optional: --require-env DB_HOST

readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly REPO_ROOT="$(git rev-parse --show-toplevel)"

# Defaults
branches="v1/fail/*"
filter=""
keep_worktrees=false
worktree_root=".sisyphus/worktrees"
timeout_opencode_sec=300
timeout_rspec_sec=120
require_envs=()
print_names=false

# Parse CLI (portable long-opt parser)
while [[ $# -gt 0 ]]; do
  case "$1" in
    --branches)
      branches="$2"
      shift 2
      ;;
    --filter)
      filter="$2"
      shift 2
      ;;
    --keep-worktrees)
      keep_worktrees=true
      shift
      ;;
    --worktree-root)
      worktree_root="$2"
      shift 2
      ;;
    --timeout-opencode-sec)
      timeout_opencode_sec="$2"
      shift 2
      ;;
    --timeout-rspec-sec)
      timeout_rspec_sec="$2"
      shift 2
      ;;
    --require-env)
      require_envs+=("$2")
      shift 2
      ;;
    --provider-config)
      provider_config_path="$2"
      shift 2
      ;;
    --print-names)
      print_names=true
      shift
      ;;
    -h|--help)
      cat << EOF
Benchmark Runner v0.1 (Foundation)

Options:
  --branches BRANCH_GLOB (default: v1/fail/*)
  --filter REGEX
  --keep-worktrees
  --worktree-root PATH (default: .sisyphus/worktrees)
  --timeout-opencode-sec SEC (default: 300)
  --timeout-rspec-sec SEC (default: 120)
  --require-env VAR (repeatable)
  --print-names (debug: print derived names)
  --provider-config FILE (JSON with provider credentials)
  -h, --help

Env: MODEL required, opencode in PATH
Provider env vars: OPENAI_API_KEY, ANTHROPIC_API_KEY, GROQ_API_KEY, etc.
EOF
      exit 0
      ;;
    --*)
      echo "Unknown option: $1" >&2
      exit 1
      ;;
    *)
      echo "Unexpected arg: $1" >&2
      exit 1
      ;;
  esac
done

# Nix re-exec if not in shell
if [[ -z ${IN_NIX_SHELL+x} ]]; then
  exec nix develop --impure --command bash "$0" "$@"
fi

# Env gating
if [[ -z ${MODEL+x} ]]; then
  echo "Error: MODEL env var required" >&2
  exit 1
fi

if ! command -v opencode >/dev/null 2>&1; then
  echo "Error: opencode not in PATH" >&2
  exit 1
fi

# Detect opencode run flags once at startup
OPENCODE_RUN_HELP=$(opencode run --help 2>/dev/null)
HAS_PROMPT_FILE=$(echo "$OPENCODE_RUN_HELP" | grep -q -- --prompt-file && echo true || echo false)
HAS_PROMPT=$(echo "$OPENCODE_RUN_HELP" | grep -q -- --prompt && echo true || echo false)
readonly HAS_PROMPT_FILE HAS_PROMPT

provider_config_path=""

setup_provider_auth() {
  local isolated_dir="$1"
  local provider_config_path="$2"
  local auth_dir="$isolated_dir/share/opencode"
  mkdir -p "$auth_dir"
  local creds=()
  add_cred() {
    local provider="$1"
    local key_var="$2"
    if [[ -n "${!key_var:-}" ]]; then
      creds+=("{\"provider\":\"$provider\",\"type\":\"apiKey\",\"key\":\"${!key_var}\"}")
    fi
  }
  add_cred "openai" OPENAI_API_KEY
  add_cred "anthropic" ANTHROPIC_API_KEY
  add_cred "groq" GROQ_API_KEY
  add_cred "deepseek" DEEPSEEK_API_KEY
  add_cred "openrouter" OPENROUTER_API_KEY
  add_cred "xai" XAI_API_KEY
  if [[ -n "$provider_config_path" && -f "$provider_config_path" ]]; then
    while IFS= read -r cred; do
      creds+=("$cred")
    done < <(jq -r '.credentials[]? | @json' "$provider_config_path" 2>/dev/null || true)
  fi
  local creds_json
  if [[ ${#creds[@]} -eq 0 ]]; then
    creds_json="[]"
  else
    creds_json="[$(IFS=,; echo "${creds[*]}")]"
  fi
  local auth_json="{\"version\":1,\"credentials\":$creds_json}"
  echo "$auth_json" > "$auth_dir/auth.json"
}

for var in "${require_envs[@]}"; do
  if [[ -z ${!var+x} ]]; then
    echo "Error: required env '$var' not set" >&2
    exit 1
  fi
done

# Model slugify: snake_case (lower, /:@->_, collapse repeats)
model_slug() {
  local input="$1"
  echo "$input" | tr '[:upper:] /:@-' '[:lower:]_' | sed 's/_\\+/_/g; s/^_\\?//; s/_$//'
}

# Fix branch name: v1/fix/<fail_suffix>/<model_snake>
fix_branch_name() {
  local fail_branch="$1"
  local model_snake="$(model_slug "$MODEL")"
  local fail_suffix="${fail_branch#v1/fail/}"  # strip prefix
  fail_suffix="${fail_suffix%%/*}"            # first component after prefix
  echo "v1/fix/${fail_suffix}/${model_snake}"
}

# Worktree mgmt
mkdir -p "$worktree_root"

worktree_add() {
  local fail_branch="$1"
  local fix_branch="$2"
  local wt_path="$3"

  # Prune stale worktrees
  git worktree prune >/dev/null 2>&1 || true

  # Remove if exists
  if git worktree list | cut -d $'\\t' -f1 | grep -Fx "$wt_path" >/dev/null; then
    echo "Removing existing worktree: $wt_path"
    git worktree remove "$wt_path" || true
    rm -rf "$wt_path"
  fi

  # Add new (creates branch if needed)
  git worktree add "$wt_path" "$fix_branch"
  echo "Added worktree: $wt_path (fail: $fail_branch -> fix: $fix_branch)"
}

worktree_remove() {
  local wt_path="$1"
  if [[ "$keep_worktrees" == true ]]; then
    return 0
  fi
  git worktree prune >/dev/null 2>&1 || true
  if git worktree list | cut -d $'\\t' -f1 | grep -Fx "$wt_path" >/dev/null; then
    git worktree remove "$wt_path" || true
  fi
  rm -rf "$wt_path"
}

git_create_fix_branch() {
  local fail_branch="$1"
  local fix_branch="$2"
  git branch -f "$fix_branch" "$fail_branch"
}
git_get_commit_sha() {
  local worktree_path="$1"
  (cd "$worktree_path" && git rev-parse --verify HEAD 2>/dev/null) || echo ""
}
git_is_dirty() {
  local worktree_path="$1"
  cd "$worktree_path" 2>/dev/null || { echo false; return; }
  if git status --porcelain | grep -q . ; then
    echo true
  else
    echo false
  fi
}
git_auto_commit() {
  local worktree_path="$1"
  local fix_branch="$2"
  local rspec_status="$3"
  if [[ "$rspec_status" != "PASS" ]]; then
    echo ""
    return 0
  fi
  local dirty
  dirty=$(git_is_dirty "$worktree_path")
  if [[ "$dirty" != "true" ]]; then
    echo ""
    return 0
  fi
  cd "$worktree_path" || { echo ""; return 1; }
  IFS=/ read -ra parts <<< "$fix_branch"
  local fail_suffix="${parts[2]}"
  local model_snake="${parts[3]}"
  local msg="bench(fix): $fail_suffix via $model_snake"
  git add -A
  if ! git commit -m "$msg"; then
    echo ""
    return 1
  fi
  git rev-parse HEAD
}
# Track worktrees for cleanup
declare -a worktrees_to_remove=()

cleanup() {
  echo "Cleaning up worktrees..."
  for wt_path in "${worktrees_to_remove[@]}"; do
    worktree_remove "$wt_path"
  done
}

if [[ "$keep_worktrees" == false ]]; then
  trap cleanup EXIT INT TERM
fi

# Debug: print names (no execution)
if [[ "$print_names" == true ]]; then
  echo "MODEL: $MODEL"
  echo "Slug: $(model_slug "$MODEL")"
  echo "Branches glob: $branches"
  echo "Filter: $filter"
  echo "Worktree root: $worktree_root"
  echo "Timeouts: opencode=${timeout_opencode_sec}s, rspec=${timeout_rspec_sec}s"
  echo "Example: fail 'v1/fail/order_spec' -> fix '$(fix_branch_name 'v1/fail/order_spec')'"
  echo "Worktree path: $worktree_root/example"
  exit 0
fi

# Task 10: Results tracking functions

readonly RESULTS_FILE="$REPO_ROOT/.sisyphus/benchmark-results.md"

results_init() {
  mkdir -p "$(dirname "$RESULTS_FILE")"
  if [[ ! -f "$RESULTS_FILE" ]]; then
    cat > "$RESULTS_FILE" << 'EOF'
# Benchmark Results

| Timestamp | Model | Fail Branch | Fix Branch | OpenCode RC | Pre RC | Post RC | Status | Commit | Log Dir |
|-----------|-------|-------------|------------|-------------|--------|---------|--------|--------|---------|
EOF
  fi
}

results_write_baseline() {
  local model="$1"
  local rc="$2"
  local log_dir="$3"
  local status=$( [[ "$rc" -eq 0 ]] && echo "PASS" || echo "FAIL" )
  echo "| $(date +%Y%m%d-%H%M%S) | $model | v1/working | BASELINE | - | $rc | - | $status | - | $log_dir |" >> "$RESULTS_FILE"
}

results_add_row() {
  local timestamp="$1"
  local model="$2"
  local fail_branch="$3"
  local fix_branch="$4"
  local opencode_rc="$5"
  local pre_rc="$6"
  local post_rc="$7"
  local status="$8"
  local commit_sha="$9"
  local log_dir="${10}"
  echo "| $timestamp | $model | $fail_branch | $fix_branch | $opencode_rc | $pre_rc | $post_rc | $status | ${commit_sha:-N/A} | $log_dir |" >> "$RESULTS_FILE"
}

# Task 11: Main benchmark loop

main() {
  local timestamp=$(date +%Y%m%d-%H%M%S)
  local log_root="$REPO_ROOT/.sisyphus/bench-logs/$timestamp"
  mkdir -p "$log_root"

  # Initialize results file
  results_init

  # BASELINE: Run rspec on v1/working first
  echo "=== BASELINE: v1/working ==="
  local baseline_wt="$worktree_root/baseline-$timestamp"
  local baseline_env="bench_baseline"
  worktree_add "v1/working" "v1/working" "$baseline_wt" 2>/dev/null || true
  db_prepare "$baseline_wt" "$baseline_env"
  local baseline_result=$(rspec_run "$baseline_wt" "$baseline_env" "baseline")
  local baseline_rc=$(echo "$baseline_result" | jq -r '.exit_code')
  results_write_baseline "$MODEL" "$baseline_rc" "$log_root/baseline"

  if [[ "$baseline_rc" -ne 0 ]]; then
    echo "ERROR: Baseline failed (rc=$baseline_rc). Aborting."
    db_drop "$baseline_wt" "$baseline_env" 2>/dev/null || true
    worktree_remove "$baseline_wt"
    exit 1
  fi

  db_drop "$baseline_wt" "$baseline_env" 2>/dev/null || true
  worktree_remove "$baseline_wt"

  # PER-BRANCH LOOP
  local fail_branches
  if [[ -n "$filter" ]]; then
    fail_branches=$(git branch -l "$branches" | sed 's/^[* ]*//' | grep -E "$filter" || true)
  else
    fail_branches=$(git branch -l "$branches" | sed 's/^[* ]*//' || true)
  fi

  if [[ -z "$fail_branches" ]]; then
    echo "No branches matching '$branches' (filter: '$filter')"
    exit 0
  fi

  for fail_branch in $fail_branches; do
    echo ""
    echo "=== Processing: $fail_branch ==="

    local fail_suffix=${fail_branch#v1/fail/}
    local fix_branch=$(fix_branch_name "$fail_branch")
    local wt_path="$worktree_root/$fail_suffix/$(model_slug "$MODEL")"
    local branch_log="$log_root/$fail_suffix"
    mkdir -p "$branch_log"

    # Skip if fix branch already exists
    if git branch --list "$fix_branch" | grep -q "$fix_branch"; then
      echo "SKIP: Fix branch $fix_branch already exists"
      results_add_row "$timestamp" "$MODEL" "$fail_branch" "$fix_branch" "N/A" "N/A" "N/A" "SKIPPED" "" "$branch_log"
      continue
    fi

    # Create fix branch from fail branch, then worktree
    git_create_fix_branch "$fail_branch" "$fix_branch"
    worktrees_to_remove+=("$wt_path")
    worktree_add "$fail_branch" "$fix_branch" "$wt_path"

    # DB isolation
    local test_env=$(db_test_env_number "$fail_suffix")
    db_prepare "$wt_path" "$test_env"

    # RSpec PRE
    echo "Running rspec (pre)..."
    local pre_result=$(rspec_run "$wt_path" "$test_env" "pre")
    local pre_rc=$(echo "$pre_result" | jq -r '.exit_code')
    local pre_log=$(echo "$pre_result" | jq -r '.log_path')

    # Generate PROMPT.md
    generate_prompt_md "$wt_path" "$fail_branch" "$pre_log"

    # Run opencode
    echo "Running opencode..."
    local prompt_path="$wt_path/PROMPT.md"
    local opencode_result=$(opencode_run "$wt_path" "$prompt_path")
    local opencode_rc=$(echo "$opencode_result" | jq -r '.exit_code')

    # RSpec POST
    echo "Running rspec (post)..."
    local post_result=$(rspec_run "$wt_path" "$test_env" "post")
    local post_rc=$(echo "$post_result" | jq -r '.exit_code')
    local post_status=$(echo "$post_result" | jq -r '.status')

    # Auto-commit if PASS
    local commit_sha=""
    if [[ "$post_status" == "PASS" ]]; then
      commit_sha=$(git_auto_commit "$wt_path" "$fix_branch" "$post_status")
    fi

    # Record results
    results_add_row "$timestamp" "$MODEL" "$fail_branch" "$fix_branch" "$opencode_rc" "$pre_rc" "$post_rc" "$post_status" "$commit_sha" "$branch_log"

    # Cleanup DB
    db_drop "$wt_path" "$test_env" 2>/dev/null || true

    echo "Done: $fail_branch -> $post_status"
  done

  echo ""
  echo "=== Benchmark Complete ==="
  echo "Results: $RESULTS_FILE"
  echo "Logs: $log_root"
}

# Run main (unless --print-names)
if [[ "$print_names" != true ]]; then
  main
fi

generate_prompt_md() {
  local worktree_path="$1"
  local fail_branch="$2"
  local rspec_pre_log="$3"

  local prompt_md="$worktree_path/PROMPT.md"

  cat > "$prompt_md" << 'HEADER'
## Project Context

This is a **Ruby on Rails 8.1 API-only** application implementing an **Order and Inventory Management System**. The system manages products, warehouses, and inventory stock, handling the full lifecycle of an order from pending to confirmed or cancelled.

### Key Features
- **Multi-Warehouse Support**: Inventory is tracked per warehouse.
- **Stock Allocation Logic**: Orders are confirmed by deducting stock from warehouses in ascending ID order.
- **Atomic Transactions**: Inventory deductions and order status updates are performed within database transactions to ensure data integrity.
- **Inventory Restoration**: Cancelling a confirmed order accurately restores stock to the original warehouses using an allocation tracking system.
- **State Integrity**: Strict guards prevent modifying orders once they are confirmed or cancelled.
- **Deterministic Business Logic**: All line total and order total calculations are performed within the application domain.

### Tech Stack
- **Language**: Ruby 3.x
- **Framework**: Rails 8.1 (API-only mode)
- **Database**: PostgreSQL
- **Testing**: RSpec, FactoryBot, Shoulda Matchers

See full details in AGENTS.md.
HEADER

  cat >> "$prompt_md" << 'GOAL'
## Current Branch Being Repaired
$fail_branch

## Goal
Make `bundle exec rspec` pass completely.

GOAL

  echo '## Failing RSpec Output' >> "$prompt_md"
  echo '```' >> "$prompt_md"
  printf '%s\n' "$rspec_pre_log" >> "$prompt_md"
  echo '```' >> "$prompt_md"

  cat >> "$prompt_md" << 'INSTRUCTIONS'

## Instructions for AI Agent

- Analyze the failing tests in the provided RSpec output.
- Fix the code to make all tests pass.
- **Do NOT change intended business rules** - preserve the exact logic described in AGENTS.md.
- **Avoid scope creep**: Only fix what's necessary for tests to pass. Do not add new features or refactor unrelated code.
- Use available tools (read, edit, lsp_*, bash for rspec, etc.) to diagnose and fix.
- Run `bundle exec rspec` yourself to verify fixes.
- If changes are made, commit them with a concise message like 'fix rspec failures'.
- Operate non-interactively: no questions to user, complete autonomously.

INSTRUCTIONS
  echo "Created PROMPT.md at $prompt_md"
}

# Task 4: DB Isolation Functions

db_test_env_number() {
  local fail_suffix="$1"
  local slug=$(echo "$fail_suffix" | tr '[:upper:] /:@-.' '[:lower:]________' | sed 's/_\+/_/g' | sed 's/^_\?//; s/_$//' | cut -c1-9)
  echo "bench_$slug"
}


db_prepare() {
  local worktree_path="$1"
  local test_env_number="$2"
  local log_file="$worktree_path/db_prepare.log"
  cd "$worktree_path" || { echo "Failed to cd to $worktree_path" >&2; return 1; }
  timeout ${timeout_rspec_sec}s bash -c "
    RAILS_ENV=test TEST_ENV_NUMBER='$test_env_number' bin/rails db:prepare 2>&1 | tee '$log_file'
  " || {
    echo "db_prepare failed for $test_env_number (check $log_file)" >&2
    return 1
  }
  echo "db_prepare succeeded for $test_env_number"
}


db_drop() {
  local worktree_path="$1"
  local test_env_number="$2"
  local primary_db="inventory_system_test$test_env_number"
  local queue_db="${primary_db}_queue"
  cd "$worktree_path" || return 0
  echo "Dropping DBs for $test_env_number: $primary_db, $queue_db"
  # Best-effort drop via rails db:drop (handles multi-db)
  RAILS_ENV=test TEST_ENV_NUMBER='$test_env_number' bin/rails db:drop || true
  # Fallback direct dropdb if needed
  dropdb "$primary_db" >/dev/null 2>&1 || true
  dropdb "$queue_db" >/dev/null 2>&1 || true
  echo "db_drop completed for $test_env_number (best-effort)"
}


db_isolation_setup() {
  local worktree_path="$1"
  local fail_suffix="$2"
  local test_env_number=$(db_test_env_number "$fail_suffix")
  db_prepare "$worktree_path" "$test_env_number"
}


db_isolation_cleanup() {
  local worktree_path="$1"
  local fail_suffix="$2"
  local test_env_number=$(db_test_env_number "$fail_suffix")
  db_drop "$worktree_path" "$test_env_number"
}

rspec_run() {
    local worktree_path="$1"
    local test_env_number="$2"
    local phase="$3"

    local repo_root
    repo_root=$(cd "$worktree_path" && git rev-parse --show-toplevel)
    local timestamp=$(date +%Y-%m-%d-%H%M%S)
    local branch_name=$(basename "$worktree_path")
    local log_dir="$repo_root/.sisyphus/bench-logs/${timestamp}/${branch_name}"
    mkdir -p "$log_dir"
    local log_path="${log_dir}/rspec-${phase}.log"
    local bundle_cache="${repo_root}/.sisyphus/bundle-cache"
    mkdir -p "$bundle_cache"

    local start_sec=$(date +%s)

    cd "$worktree_path" || {
        echo "{\"exit_code\":1,\"elapsed_sec\":0,\"status\":\"FAIL\",\"log_path\":\"$log_path\"}"
        return 1
    }

    timeout "${timeout_rspec_sec}s" \
        env BUNDLE_PATH="$bundle_cache" TEST_ENV_NUMBER="$test_env_number" \
        bundle exec rspec \
        > "$log_path" 2>&1

    local exit_code=$?
    local elapsed_sec=$(( $(date +%s) - start_sec ))
    local status=$( [[ $exit_code -eq 0 ]] && echo "PASS" || echo "FAIL" )

    echo "{\"exit_code\":$exit_code,\"elapsed_sec\":$elapsed_sec,\"status\":\"$status\",\"log_path\":\"$log_path\"}"
}

opencode_run() {
    local worktree_path="$1"
    local prompt_path="$2"

    local repo_root
    repo_root=$(cd "$worktree_path" && git rev-parse --show-toplevel)
    local timestamp=$(date +%Y-%m-%d-%H%M%S)
    local branch_name=$(basename "$worktree_path")
    local log_dir="$repo_root/.sisyphus/bench-logs/${timestamp}/${branch_name}"
    mkdir -p "$log_dir"
    local log_path="${log_dir}/opencode.log"

    local start_sec=$(date +%s)

    cd "$worktree_path" || {
        echo "{\"exit_code\":1,\"elapsed_sec\":0,\"log_path\":\"$log_path\"}"
        return 1
    }

    opencode_setup_isolation "$worktree_path"

    if [[ "$HAS_PROMPT_FILE" == true ]]; then
        timeout "${timeout_opencode_sec}s" opencode run --model "$MODEL" --prompt-file "$prompt_path" --dir . > "$log_path" 2>&1
    elif [[ "$HAS_PROMPT" == true ]]; then
        local prompt_content
        prompt_content=$(cat "$prompt_path")
        timeout "${timeout_opencode_sec}s" opencode run --model "$MODEL" --prompt "$prompt_content" --dir . > "$log_path" 2>&1
    else
        timeout "${timeout_opencode_sec}s" opencode run --model "$MODEL" --dir . < "$prompt_path" > "$log_path" 2>&1
    fi

    local exit_code=$?
    local elapsed_sec=$(( $(date +%s) - start_sec ))

    echo "{\"exit_code\":$exit_code,\"elapsed_sec\":$elapsed_sec,\"log_path\":\"$log_path\"}"
}

opencode_setup_isolation() {
  local worktree_path="$1"
  local isolated_dir="$worktree_path/.opencode-isolated"
  mkdir -p "$isolated_dir"/{config,share,cache,state}
  export XDG_CONFIG_HOME="$isolated_dir/config"
  export XDG_DATA_HOME="$isolated_dir/share"
  export XDG_CACHE_HOME="$isolated_dir/cache"
  export XDG_STATE_HOME="$isolated_dir/state"
  export OPENCODE_DISABLE_CLAUDE_CODE=1
  setup_provider_auth "$isolated_dir" "$provider_config_path"
}
